APP_NAME="Portal SI"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_API_URL=http://localhost:8000

# Comma-separated browser origins allowed by CORS. Leave empty for a
# mobile-only API (native clients do not enforce CORS).
CORS_ALLOWED_ORIGINS=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database (MySQL) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=portalsi
DB_USERNAME=root
DB_PASSWORD=

# --- Drivers ---
# Local default: null (no realtime server needed). Without it, every
# broadcasting action (follow, like, comment, message) 500s when no
# Reverb/Pusher is running. Use reverb or pusher in production.
BROADCAST_CONNECTION=null
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# --- Redis (optional; used by predis) ---
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail ---
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@portalsi.com"
MAIL_FROM_NAME="${APP_NAME}"
EMAIL_VERIFICATION_RESEND_COOLDOWN=60

# --- AWS S3 (media storage) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Laravel Reverb (WebSockets) ---
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

# --- Pusher (fallback / pusher-php-server) ---
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# --- Firebase Cloud Messaging (kreait/firebase-php) ---
# Path to the service-account JSON (keep OUT of version control)
FIREBASE_CREDENTIALS=storage/app/firebase/service-account.json
FIREBASE_PROJECT_ID=portalsi-web-real
